{
  "manifest_version": 3,
  "name": "Lx Draft",
  "version": "1.1",
  "description": "在浏览器右侧常驻的文本草稿空间",
  "permissions": ["storage", "sidePanel"],
  "action": {
    "default_title": "点击打开草稿箱"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}