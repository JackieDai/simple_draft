{
  "manifest_version": 3,
  "name": "Simple Draft Bottom",
  "version": "1.3",
  "description": "支持自由缩放、居中输入的底部沉浸式草稿箱",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "128": "icon.png"
  }
}